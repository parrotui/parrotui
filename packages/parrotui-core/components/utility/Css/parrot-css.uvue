  border-right-color: #ebeef5;
}

.pui-hairline-all {
  border-width: 0.5px;
  border-style: solid;
  border-color: #ebeef5;
}

/* ---- 显示/隐藏 ---- */
.pui-hidden {
  display: none;
}

/* ---- 宽高 ---- */
.pui-full-width {
