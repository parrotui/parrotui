<template>
  <!-- Css 常用样式工具类：纯 CSS 输出，无 JS 逻辑 -->
  <!-- 使用方法：在页面中引入此组件，即可在页面内使用 .pui-* 系列工具 class -->
  <view class="parrot-css">
    <slot></slot>
  </view>
</template>

<script setup lang="uts">
/**
 * parrot-css 常用样式工具类组件
 * 纯 CSS class 输出，不含任何 Props/Events。
 * 提供 Flex 布局、文字截断、安全区域、细线边框等常用工具样式。
 *
 * 可用 class 列表：
 * - .pui-flex            横向 flex
 * - .pui-flex-column     纵向 flex
 * - .pui-flex-wrap       允许换行
 * - .pui-flex-center     水平垂直居中
 * - .pui-flex-between    两端对齐
 * - .pui-flex-around     等间距
 * - .pui-flex-1          flex:1
 * - .pui-text-left       文字左对齐
 * - .pui-text-center     文字居中
 * - .pui-text-right      文字右对齐
 * - .pui-ellipsis        单行溢出省略
 * - .pui-ellipsis-2      两行溢出省略
 * - .pui-safe-bottom     安全区域底部间距
 * - .pui-hairline-top    上方 0.5px 细线
 * - .pui-hairline-bottom 下方 0.5px 细线
 * - .pui-hidden          隐藏元素
 * - .pui-full-width      宽度 100%
 * - .pui-block           块级显示
 * - .pui-inline          内联 flex
 * - .pui-relative        相对定位
 * - .pui-absolute        绝对定位
 * - .pui-fixed           固定定位
 */
</script>

<style>
/* ============================================================
   Parrot UI 通用工具类
   注意：此处使用非 scoped style，以便全局可用
   ============================================================ */

/* ---- Flex 布局 ---- */
.pui-flex {
  display: flex;
  flex-direction: row;
}

.pui-flex-column {
  display: flex;
  flex-direction: column;
}

.pui-flex-wrap {
  flex-wrap: wrap;
}

.pui-flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.pui-flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.pui-flex-around {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
}

.pui-flex-start {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
}

.pui-flex-end {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
}

.pui-flex-1 {
  flex: 1;
}

.pui-flex-shrink-0 {
  flex-shrink: 0;
}

/* ---- 文字对齐 ---- */
.pui-text-left {
  text-align: left;
}

.pui-text-center {
  text-align: center;
}

.pui-text-right {
  text-align: right;
}

/* ---- 文字截断 ---- */
.pui-ellipsis {
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.pui-ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.pui-ellipsis-3 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

/* ---- 安全区域 ---- */
.pui-safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.pui-safe-top {
  padding-top: env(safe-area-inset-top);
}

/* ---- 细线边框（0.5px hairline） ---- */
.pui-hairline-top {
  border-top-width: 0.5px;
  border-top-style: solid;
  border-top-color: #ebeef5;
}

.pui-hairline-bottom {
  border-bottom-width: 0.5px;
