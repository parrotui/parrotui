	display: flex;
	flex-direction: column;
	align-items: center;
	min-height: 100vh;
	background-color: #ffffff;
	padding: 0 60rpx;
}

/* 头部区域 */
.parrot-login-a__header {
	display: flex;
	flex-direction: column;
	align-items: center;
	padding-top: 180rpx;
	padding-bottom: 80rpx;
}

.parrot-login-a__logo {
	width: 160rpx;
	height: 160rpx;
	margin-bottom: 32rpx;
	border-radius: 28rpx;
}

.parrot-login-a__logo-placeholder {
	width: 160rpx;
	height: 160rpx;
	margin-bottom: 32rpx;
	border-radius: 28rpx;
	background-color: #f0f4ff;
	display: flex;
	align-items: center;
	justify-content: center;
}

.parrot-login-a__logo-text {
	font-size: 32rpx;
	font-weight: 700;
	color: #1a7eff;
}

.parrot-login-a__title {
	font-size: 48rpx;
	font-weight: 700;
	color: #1a1a1a;
	line-height: 68rpx;
}

.parrot-login-a__subtitle {
	font-size: 26rpx;
	color: #909399;
	margin-top: 12rpx;
	line-height: 38rpx;
}

/* 表单区域 */
.parrot-login-a__form {
	width: 100%;
}

.parrot-login-a__field {
	margin-bottom: 32rpx;
}

.parrot-login-a__input-wrap {
	display: flex;
	flex-direction: row;
	align-items: center;
	height: 96rpx;
	background-color: #f5f7fa;
	border-radius: 16rpx;
	padding: 0 28rpx;
}

.parrot-login-a__input-icon {
	font-size: 36rpx;
	margin-right: 16rpx;
}

.parrot-login-a__input {
	flex: 1;
	height: 96rpx;
	font-size: 30rpx;
	color: #303133;
	background-color: transparent;
}

.parrot-login-a__eye {
	padding: 0 8rpx;
	display: flex;
	align-items: center;
}

.parrot-login-a__eye-icon {
	font-size: 36rpx;
}

/* 登录按钮 */
.parrot-login-a__btn {
	width: 100%;
	height: 96rpx;
	background-color: #1a7eff;
	border-radius: 16rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	margin-top: 24rpx;
}

.parrot-login-a__btn--disabled {
	opacity: 0.5;
}

.parrot-login-a__btn-text {
	font-size: 32rpx;
	font-weight: 600;
	color: #ffffff;
}

/* 底部注册 */
.parrot-login-a__footer {
	display: flex;
	flex-direction: row;
	align-items: center;
	justify-content: center;
	margin-top: 48rpx;
}

.parrot-login-a__footer-text {
	font-size: 26rpx;
	color: #909399;
}

.parrot-login-a__footer-link {
	font-size: 26rpx;
	color: #1a7eff;
	font-weight: 500;
	margin-left: 8rpx;
}
</style>
