<template>
	<!-- LoginC 第三方登录模板：品牌背景 + Logo + 一键登录 + 第三方图标行 -->
	<view class="parrot-login-c">
		<!-- 品牌色背景区域 -->
		<view class="parrot-login-c__brand" :style="brandBgStyle">
			<!-- Logo -->
			<view class="parrot-login-c__logo-area">
				<image
					v-if="logo"
					class="parrot-login-c__logo"
					:src="logo"
					mode="aspectFit"
				/>
				<view v-if="!logo" class="parrot-login-c__logo-default">
					<text class="parrot-login-c__logo-default-text">LOGO</text>
				</view>
				<text class="parrot-login-c__title">{{ title }}</text>
			</view>

			<!-- 一键登录按钮 -->
			<view class="parrot-login-c__quick-btn" @tap="handleQuickLogin">
				<text class="parrot-login-c__quick-btn-text">一键登录</text>
			</view>
		</view>

		<!-- 底部白色区域：第三方登录 -->
		<view class="parrot-login-c__bottom">
			<view class="parrot-login-c__divider-row">
				<view class="parrot-login-c__divider-line"></view>
				<text class="parrot-login-c__divider-text">其他方式登录</text>
				<view class="parrot-login-c__divider-line"></view>
			</view>

			<!-- 第三方登录图标行 -->
			<view class="parrot-login-c__providers">
				<view
					v-for="(item, index) in providerList"
					:key="index"
					class="parrot-login-c__provider-item"
					@tap="handleThirdLogin(item['id'] as string)"
				>
					<view class="parrot-login-c__provider-icon" :style="providerIconStyle(item)">
						<text class="parrot-login-c__provider-icon-text">{{ item['icon'] as string }}</text>
					</view>
					<text class="parrot-login-c__provider-label">{{ item['label'] as string }}</text>
				</view>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
/**
 * LoginC 第三方登录模板
 * 社交登录页：大面积品牌背景色 + 中央 Logo + 一键登录按钮 + 底部第三方图标行
 *
 * @prop logo         Logo 图片地址
 * @prop title        页面标题
 * @prop brandColor   品牌主色
 * @prop providers    第三方登录列表 JSON 数组字符串
 *
 * @event quickLogin   点击一键登录
 * @event thirdLogin   点击第三方登录，返回 provider id
 */
import { ref, computed } from 'vue'

interface Props {
	logo ?: string
	title ?: string
	brandColor ?: string
	providers ?: string
}

const props = withDefaults(defineProps<Props>(), {
	logo: '',
	title: '一键登录',
	brandColor: '#1a7eff',
	providers: '[{"id":"wechat","icon":"微","label":"微信","color":"#07c160"},{"id":"qq","icon":"Q","label":"QQ","color":"#12b7f5"},{"id":"weibo","icon":"微","label":"微博","color":"#e6162d"},{"id":"apple","icon":"A","label":"Apple","color":"#000000"}]',
})

const emit = defineEmits<{
	quickLogin: []
	thirdLogin: [provider: string]
}>()

// 品牌背景样式
const brandBgStyle = computed(() : string => {
	return `background-color:${props.brandColor ?? '#1a7eff'}`
})

// 解析第三方登录列表
const providerList = computed(() : UTSJSONObject[] => {
	const result : UTSJSONObject[] = []
	const raw = props.providers ?? '[]'
	const arr = JSON.parse(raw) as UTSJSONObject[]
	if (arr != null) {
		for (let i = 0; i < arr.length; i++) {
			result.push(arr[i])
		}
	}
	return result
})

// 第三方图标样式
function providerIconStyle(item : UTSJSONObject) : string {
	const color = (item['color'] as string) ?? '#333333'
	return `background-color:${color}`
}

// 一键登录
function handleQuickLogin() {
	emit('quickLogin')
}

// 第三方登录
function handleThirdLogin(provider : string) {
	emit('thirdLogin', provider)
}
</script>

<style scoped>
