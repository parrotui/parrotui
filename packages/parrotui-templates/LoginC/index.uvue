	display: flex;
	flex-direction: column;
	min-height: 100vh;
	background-color: #ffffff;
}

/* 品牌色区域 */
.parrot-login-c__brand {
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	flex: 1;
	padding: 0 60rpx;
	padding-bottom: 80rpx;
}

/* Logo 区域 */
.parrot-login-c__logo-area {
	display: flex;
	flex-direction: column;
	align-items: center;
	margin-bottom: 80rpx;
}

.parrot-login-c__logo {
	width: 180rpx;
	height: 180rpx;
	margin-bottom: 32rpx;
	border-radius: 36rpx;
}

.parrot-login-c__logo-default {
	width: 180rpx;
	height: 180rpx;
	margin-bottom: 32rpx;
	border-radius: 36rpx;
	background-color: rgba(255, 255, 255, 0.25);
	display: flex;
	align-items: center;
	justify-content: center;
}

.parrot-login-c__logo-default-text {
	font-size: 36rpx;
	font-weight: 700;
	color: #ffffff;
}

.parrot-login-c__title {
	font-size: 44rpx;
	font-weight: 700;
	color: #ffffff;
	line-height: 64rpx;
}

/* 一键登录按钮 */
.parrot-login-c__quick-btn {
	width: 100%;
	height: 96rpx;
	background-color: #ffffff;
	border-radius: 48rpx;
	display: flex;
	align-items: center;
	justify-content: center;
}

.parrot-login-c__quick-btn-text {
	font-size: 32rpx;
	font-weight: 600;
	color: #1a7eff;
}

/* 底部白色区域 */
.parrot-login-c__bottom {
	background-color: #ffffff;
	padding: 48rpx 60rpx;
	padding-bottom: 80rpx;
	border-top-left-radius: 40rpx;
	border-top-right-radius: 40rpx;
	margin-top: -40rpx;
}

/* 分割线 */
.parrot-login-c__divider-row {
	display: flex;
	flex-direction: row;
	align-items: center;
	margin-bottom: 48rpx;
}

.parrot-login-c__divider-line {
	flex: 1;
	height: 1rpx;
	background-color: #e4e7ed;
}

.parrot-login-c__divider-text {
	font-size: 24rpx;
	color: #909399;
	padding: 0 24rpx;
}

/* 第三方登录列表 */
.parrot-login-c__providers {
	display: flex;
	flex-direction: row;
	justify-content: center;
}

.parrot-login-c__provider-item {
	display: flex;
	flex-direction: column;
	align-items: center;
	margin: 0 28rpx;
}

.parrot-login-c__provider-icon {
	width: 96rpx;
	height: 96rpx;
	border-radius: 50%;
	display: flex;
	align-items: center;
	justify-content: center;
	margin-bottom: 12rpx;
}

.parrot-login-c__provider-icon-text {
	font-size: 36rpx;
	font-weight: 700;
	color: #ffffff;
}

.parrot-login-c__provider-label {
	font-size: 22rpx;
	color: #606266;
}
</style>
