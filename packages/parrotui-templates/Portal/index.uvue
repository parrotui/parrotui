	display: flex;
	flex-direction: column;
	min-height: 100vh;
	background-color: #f5f7fa;
}

/* 搜索栏 */
.parrot-portal__search {
	background-color: #ffffff;
	padding: 20rpx 28rpx;
	padding-top: 24rpx;
}

.parrot-portal__search-bar {
	display: flex;
	flex-direction: row;
	align-items: center;
	height: 72rpx;
	background-color: #f5f7fa;
	border-radius: 36rpx;
	padding: 0 24rpx;
}

.parrot-portal__search-icon {
	font-size: 32rpx;
	margin-right: 12rpx;
}

.parrot-portal__search-input {
	flex: 1;
	height: 72rpx;
	font-size: 28rpx;
	color: #303133;
	background-color: transparent;
}

.parrot-portal__search-clear {
	width: 36rpx;
	height: 36rpx;
	border-radius: 50%;
	background-color: #c0c4cc;
	display: flex;
	align-items: center;
	justify-content: center;
	margin-left: 8rpx;
}

.parrot-portal__search-clear-icon {
	font-size: 18rpx;
	color: #ffffff;
}

/* 轮播 Banner */
.parrot-portal__banner {
	padding: 20rpx 28rpx;
	background-color: #ffffff;
}

.parrot-portal__swiper {
	width: 100%;
	height: 320rpx;
	border-radius: 20rpx;
	overflow: hidden;
}

.parrot-portal__banner-img {
	width: 100%;
	height: 320rpx;
	border-radius: 20rpx;
}

/* 通知栏 */
.parrot-portal__notice {
	display: flex;
	flex-direction: row;
	align-items: center;
	background-color: #fffbe6;
	padding: 20rpx 28rpx;
	margin: 20rpx 28rpx 0 28rpx;
	border-radius: 12rpx;
}

.parrot-portal__notice-icon {
	font-size: 32rpx;
	margin-right: 12rpx;
}

.parrot-portal__notice-text {
	flex: 1;
	font-size: 26rpx;
	color: #e6a23c;
	overflow: hidden;
	text-overflow: ellipsis;
	lines: 1;
}

.parrot-portal__notice-arrow {
	font-size: 28rpx;
	color: #e6a23c;
	margin-left: 8rpx;
}

/* 功能宫格 */
.parrot-portal__grid {
	display: flex;
	flex-direction: row;
	flex-wrap: wrap;
	padding: 24rpx 28rpx;
	background-color: #ffffff;
	margin-top: 20rpx;
	border-radius: 20rpx;
	margin-left: 28rpx;
	margin-right: 28rpx;
}

.parrot-portal__grid-item {
	width: 25%;
	display: flex;
	flex-direction: column;
	align-items: center;
	padding: 20rpx 0;
}

.parrot-portal__grid-icon-wrap {
	width: 96rpx;
	height: 96rpx;
	border-radius: 24rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	margin-bottom: 12rpx;
}

.parrot-portal__grid-icon {
	font-size: 44rpx;
}

.parrot-portal__grid-title {
	font-size: 24rpx;
	color: #303133;
	line-height: 34rpx;
}

/* 推荐列表区域 */
.parrot-portal__section {
	margin: 20rpx 28rpx;
	background-color: #ffffff;
	border-radius: 20rpx;
	padding: 28rpx;
}

.parrot-portal__section-header {
	display: flex;
	flex-direction: row;
	align-items: center;
	justify-content: space-between;
	margin-bottom: 24rpx;
}

.parrot-portal__section-title {
	font-size: 32rpx;
	font-weight: 700;
	color: #1a1a1a;
}

.parrot-portal__section-more {
	font-size: 24rpx;
