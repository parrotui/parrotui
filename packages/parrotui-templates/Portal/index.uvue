}

.parrot-portal__list-item {
	display: flex;
	flex-direction: row;
	align-items: center;
	padding: 24rpx 0;
	border-bottom-width: 1rpx;
	border-bottom-style: solid;
	border-bottom-color: #f2f3f5;
}

.parrot-portal__list-index {
	width: 48rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	margin-right: 20rpx;
}

.parrot-portal__list-index-text {
	font-size: 28rpx;
	font-weight: 700;
	color: #c0c4cc;
}

.parrot-portal__list-index-text--hot {
	color: #f56c6c;
}

.parrot-portal__list-content {
	flex: 1;
	display: flex;
	flex-direction: column;
}

.parrot-portal__list-title {
	font-size: 28rpx;
	font-weight: 500;
	color: #303133;
	line-height: 40rpx;
}

.parrot-portal__list-desc {
	font-size: 24rpx;
	color: #909399;
	margin-top: 6rpx;
	line-height: 34rpx;
}

.parrot-portal__list-arrow {
	font-size: 28rpx;
	color: #c0c4cc;
	margin-left: 12rpx;
}
</style>
